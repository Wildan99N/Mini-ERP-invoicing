generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  phone     String?
  address   String?
  invoices  Invoice[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Invoice {
  id            Int           @id @default(autoincrement())
  invoiceNumber String        @unique
  date          DateTime
  dueDate       DateTime
  status        String        @default("PENDING") // PENDING, PAID, CANCELLED
  totalAmount   Float         @default(0)
  customerId    Int
  customer      Customer      @relation(fields: [customerId], references: [id])
  items         InvoiceItem[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model InvoiceItem {
  id          Int      @id @default(autoincrement())
  description String
  quantity    Int
  unitPrice   Float
  amount      Float
  invoiceId   Int
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}
